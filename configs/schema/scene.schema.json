{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SceneConfig",
  "type": "object",
  "required": ["seed", "fixedDeltaTime"],
  "properties": {
    "seed":            { "type": "integer", "minimum": 0 },
    "fixedDeltaTime":  { "type": "number",  "exclusiveMinimum": 0 },
    "roomMaterial":    { "type": "string" },
    "roomDimensions":  {
      "type": "object",
      "required": ["x", "y", "z"],
      "properties": { "x": {"type": "number"}, "y": {"type": "number"}, "z": {"type": "number"} }
    },
    "lighting":        { "type": "string", "enum": ["directional", "point", "area", "skybox"] },
    "objects":         {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["prefab"],
        "properties": {
          "prefab": { "type": "string" },
          "path":   { "type": "array", "items": { "type": "array", "items": { "type": "number" }, "minItems": 3, "maxItems": 3 } },
          "speed":  { "type": "number" }
        }
      }
    }
  }
}
